          },
          {
            "name": "sigma_scaled",
            "docs": [
              "σ × SCALE (positive)."
            ],
            "type": "i64"
          },
          {
            "name": "regime_flag",
            "docs": [
              "0 = NORMAL, 1 = CRITICAL."
